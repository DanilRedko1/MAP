{
  "basemap": {
    "mode": "custom",
    "id": "basemapLayers",
    "title": "Custom Basemap",
    "baseLayers": [{
      "id": "world-imagery",
      "title": "World Imagery",
      "type": "tile",
      "url": "https://example.invalid/ArcGIS/rest/services/World_Imagery/MapServer",
      "fallbackLayers": [
        {
          "type": "tile",
          "url": "https://services.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer"
        }
      ]
    }]
  },
  "operationalLayers": [
    {
      "id": "roads-network",
      "title": "Road Network",
      "type": "map-image",
      "visible": true,
      "order": 5,
      "url": "https://example.invalid/ArcGIS/rest/services/World_Street_Map/MapServer",
      "fallbackLayers": [
        {
          "type": "map-image",
          "url": "https://services.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer"
        }
      ]
    },
    {
      "id": "demo-operational-layers",
      "title": "Demo Operational Layers",
      "type": "group",
      "visible": true,
      "order": 10,
      "listMode": "show",
      "visibilityMode": "independent",
      "layers": [
        {
          "id": "sample-locations",
          "title": "Sample Locations",
          "type": "graphics",
          "visible": true,
          "order": 10,
          "listMode": "show",
          "layerProps": {
            "title": "Sample Locations"
          },
          "ui": {
            "legendTitle": "Sample city markers",
            "enableExtentFilter": true,
            "filterableFields": [
              {
                "field": "region",
                "label": "Region",
                "type": "select",
                "options": [
                  {
                    "label": "East",
                    "value": "East"
                  },
                  {
                    "label": "Mountain",
                    "value": "Mountain"
                  },
                  {
                    "label": "West",
                    "value": "West"
                  }
                ]
              },
              {
                "field": "title",
                "label": "City name",
                "type": "text",
                "placeholder": "Search by city name"
              }
            ],
            "displayFields": [
              {
                "field": "title",
                "label": "City"
              },
              {
                "field": "region",
                "label": "Region"
              },
              {
                "field": "category",
                "label": "Category"
              },
              {
                "field": "description",
                "label": "Description"
              }
            ],
            "clustering": {
              "enabled": false
            },
            "timeAware": false
          },
          "graphics": [
            {
              "geometry": {
                "type": "point",
                "longitude": -74.006,
                "latitude": 40.7128
              },
              "symbol": {
                "type": "simple-marker",
                "color": "#0b6e4f",
                "size": 10,
                "outline": {
                  "color": "#ffffff",
                  "width": 1.5
                }
              },
              "attributes": {
                "title": "New York City",
                "region": "East",
                "category": "Metro",
                "description": "Sample marker with popup content in Lower Manhattan."
              },
              "popupTemplate": {
                "title": "{title}",
                "content": "{description}"
              }
            },
            {
              "geometry": {
                "type": "point",
                "longitude": -104.9903,
                "latitude": 39.7392
              },
              "symbol": {
                "type": "simple-marker",
                "color": "#0b6e4f",
                "size": 10,
                "outline": {
                  "color": "#ffffff",
                  "width": 1.5
                }
              },
              "attributes": {
                "title": "Denver",
                "region": "Mountain",
                "category": "Metro",
                "description": "A second graphic to demonstrate multiple features on the map."
              },
              "popupTemplate": {
                "title": "{title}",
                "content": "{description}"
              }
            },
            {
              "geometry": {
                "type": "point",
                "longitude": -122.4194,
                "latitude": 37.7749
              },
              "symbol": {
                "type": "simple-marker",
                "color": "#0b6e4f",
                "size": 10,
                "outline": {
                  "color": "#ffffff",
                  "width": 1.5
                }
              },
              "attributes": {
                "title": "San Francisco",
                "region": "West",
                "category": "Metro",
                "description": "West coast sample point with a consistent popup template."
              },
              "popupTemplate": {
                "title": "{title}",
                "content": "{description}"
              }
            }
          ]
        }
      ]
    }
  ]
}
